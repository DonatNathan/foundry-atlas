# Deployment environment for the Foundry Atlas API (Docker Compose / VPS).
# Copy to `.env` (repo root) and fill in. Do NOT commit the real `.env`.
# Compose reads this automatically for ${...} interpolation in its config.

# Database connection settings. Change these to match your Postgres setup.
PGHOST=localhost
PGPORT=5432
PGUSER=myuser
PGPASSWORD=change-me-to-a-strong-password
PGDATABASE=foundry_atlas

# Used to sign JWTs for authentication. Must be a strong secret.
ADMIN_TOKEN=insert-a-strong-admin-token-here

# Allowed frontend origin(s) for CORS.
CORS_ORIGIN=http://localhost:5173

# Port the API listens on.
PORT=4000
