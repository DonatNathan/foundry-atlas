# Docker Compose configuration. Copy to `.env` (repo root); do NOT commit the real one.
# Compose reads this automatically for ${...} interpolation in docker-compose.yml.

# Postgres password (used by both the db and api services). Any characters are
# fine — Compose passes it directly, no URL encoding.
POSTGRES_PASSWORD=use-a-strong-password

# Secret that unlocks editing. Generate a fresh one: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-a-long-random-string

# Allowed frontend origin for CORS — your Cloudflare Pages domain.
CORS_ORIGIN=https://map.yourdomain.com
