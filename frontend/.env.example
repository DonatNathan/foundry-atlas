# Frontend build-time config. Copy to .env for local overrides (optional).
#
# Where the API lives. Leave empty for local dev — the Vite proxy forwards
# /api to http://localhost:4000. In production (Cloudflare Pages), set this to
# your API origin so the static site calls the VPS directly.
#
# VITE_API_BASE=https://api.yourdomain.com
