# Copy to server/.env and fill in. Do not commit the real .env.

# PostgreSQL connection string.
DATABASE_URL=postgres://user:password@localhost:5432/foundry_atlas

# Set to "require" if your Postgres provider needs SSL (most managed ones do).
# PGSSL=require

# Secret that unlocks editing. Use a long random value, e.g. `openssl rand -hex 32`.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Port the API listens on (optional, defaults to 4000).
PORT=4000
